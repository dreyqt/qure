---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | QUREIT Pest Control" currentPath="/">
  <section class="min-h-[70vh] flex flex-col items-center justify-center px-6">
    <h1 class="text-6xl font-bold mb-6">404</h1>
    <p class="text-xl text-gray-600 mb-6">Sorry, the page you’re looking for doesn’t exist.</p>
    <a
      href="/"
      class="inline-block bg-[#FF6B35] hover:bg-[#e55a2a] text-white px-6 py-3 rounded-md transition-colors"
    >
      Back to Home
    </a>
  </section>
</BaseLayout>
